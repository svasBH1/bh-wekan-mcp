# Wekan MCP Configuration
# Copy this to .env and fill in your values
# IMPORTANT: This file is git-ignored. Do not commit secrets.

# Wekan instance URL
WEKAN_URL=https://wekan.example.com

# Service account API token (from Wekan / API tokens)
WEKAN_API_TOKEN=your_token_here

# Service account user ID (required for add_card, add_comment)
WEKAN_USER_ID=your_user_id_here

# Target Wekan version (for debugging)
WEKAN_VERSION=7.60.0